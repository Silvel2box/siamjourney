generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Newsletter subscribers — first DB-backed feature.
model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())

  // Lowercase table name — Windows MySQL forces lowercase, Linux is case-sensitive.
  // Explicit @@map keeps generated SQL identical on both so migrations stay portable.
  @@map("subscriber")
}

// Shop owner account (login identity + basic business info in one).
model Merchant {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  shopName     String
  status       String    @default("pending")   // pending | approved | suspended
  role         String    @default("merchant")  // merchant | admin
  // Shop profile — edited on /dashboard, shown on /shop/[id] once approved.
  description  String?   @db.Text
  province     String?   // province slug (see lib/content getAllProvinces)
  category     String?   // category slug (see lib/categories)
  address      String?
  phone        String?
  website      String?
  image        String?   @db.Text
  createdAt    DateTime  @default(now())
  sessions     Session[]

  @@map("merchant")
}

// Tourist place (attraction/restaurant/cafe/otop). Migrated from content/places
// markdown so non-dev staff can manage it in the admin. imageCredit + affiliate
// keep their nested object shape as JSON so the read layer / DTO stay identical.
model Place {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  category    String // category slug (see lib/categories)
  province    String // province slug (see lib/content)
  summary     String   @db.Text
  image       String   @db.Text
  imageCredit Json? // { author, source, sourceUrl, license? }
  address     String?
  hours       String?
  priceRange  String?
  lat         Float?
  lng         Float?
  affiliate   Json? // { label, url }
  sponsored   Int      @default(0) // 0 = ปกติ, 1 = featured, 2 = พาร์ทเนอร์จ่ายเงิน
  body        String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([province])
  @@index([category])
  @@map("place")
}

// Province landing page content. Migrated from content/provinces markdown.
model Province {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  nameEn      String
  region      String // region slug (see lib/regions)
  summary     String   @db.Text
  image       String   @db.Text
  imageCredit Json?
  featured    Boolean  @default(false)
  body        String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([region])
  @@map("province")
}

// Hotel / accommodation listing. Same shape as Place minus the 4-category
// taxonomy (hotels aren't attraction/restaurant/cafe/otop). affiliate holds the
// booking deep-link { label, url } and reuses AffiliateButton (agoda/booking).
model Hotel {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  province    String // province slug (see lib/content)
  summary     String   @db.Text
  image       String   @db.Text
  imageCredit Json? // { author, source, sourceUrl, license? }
  address     String?
  priceRange  String?
  lat         Float?
  lng         Float?
  affiliate   Json? // { label, url } — booking deep-link
  sponsored   Int      @default(0) // 0 = ปกติ, 1 = แนะนำ, 2 = พาร์ทเนอร์จ่ายเงิน
  body        String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([province])
  @@map("hotel")
}

// Opaque server-side session; the id is the random token stored in the cookie.
model Session {
  id         String   @id
  merchantId Int
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([merchantId])
  @@map("session")
}
